# Thought Atlas UI local development env
# Copy to .env.local and fill from Firebase web app config when starting Firestore read-only integration.
# Do not commit .env.local.

VITE_DATA_MODE=firestore
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=thought-atlas
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
